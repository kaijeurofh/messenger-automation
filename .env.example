# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The PoC backend talks to a local Ollama instance running on the host.

# --- Ollama -----------------------------------------------------------------
# Inside docker-compose the backend reaches the host's Ollama at
# host.docker.internal:11435 (Linux gets host-gateway via extra_hosts).
# For local non-docker runs use http://localhost:11435/v1.
#
# Start Ollama on 11435 with: OLLAMA_HOST=0.0.0.0:11435 ollama serve

OLLAMA_BASE_URL=http://host.docker.internal:11435/v1
OLLAMA_MODEL=gemma4:31b

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# In the docker-compose setup the frontend proxies via nginx so this can
# stay restrictive. Set to "*" only for local browser tests.
CORS_ORIGINS=*

# --- Host-side ports --------------------------------------------------------
# Override these if 8000 / 8080 collide with another service on your host.
# The container-internal ports (8000 for the API, 80 for nginx) do not
# change — only what gets published on the host.

BACKEND_PORT=8000
FRONTEND_PORT=8080

# --- Future Twilio integration ---------------------------------------------
# Not wired in the PoC; messages render in the frontend instead. Leave the
# placeholders so future code knows which names to read.

TWILIO_ACCOUNT_SID=replace-me
TWILIO_AUTH_TOKEN=replace-me
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
