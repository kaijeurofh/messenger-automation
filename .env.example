# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The agent reads PYDANTIC_AI_MODEL to decide which provider/model to talk to.
# Format: "provider:model-name" (see https://ai.pydantic.dev/models/).

PYDANTIC_AI_MODEL=openai:gpt-5.2

# --- Provider API keys ------------------------------------------------------
# Only the key for the provider in PYDANTIC_AI_MODEL is required.

OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
GEMINI_API_KEY=replace-me
